---
import {Image} from "astro:assets";
import Key from "./images/keys.tiff";
---

<Image src={Key} alt="Keys" loading="eager" fetchpriority="high" layout="constrained" format="avif" width={696} />

<style>
	img {
		display: block;
		width: 100%;
		height: auto;
		opacity: 0.5;
		transform: rotate(3deg);
		transition:
			transform 0.2s ease,
			opacity 0.2s ease;
	}

	img:hover {
		transform: rotate(0deg);
		opacity: 0.8;
	}
</style>
