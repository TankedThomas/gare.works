---
import {Image} from "astro:assets";

const {src, alt, rotation = -3} = Astro.props;
---

<Image src={src} alt={alt} loading="eager" fetchpriority="high" layout="constrained" format="avif" width={696} style={`--rotation: ${rotation}deg`} />

<style>
	img {
		display: block;
		width: 100%;
		height: auto;
		opacity: 0.5;
		transition:
			transform 0.2s ease,
			opacity 0.2s ease;
	}

	img:hover {
		transform: rotate(0deg);
		opacity: 0.8;
	}
</style>
