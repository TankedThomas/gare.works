---
import HeroImage from "../assets/HeroImage.astro";
import Chips from "../assets/images/chips.tiff";
import Keys from "../assets/images/keys.tiff";
import Schematic from "../assets/images/schematic.tiff";
import Spectrum from "../assets/images/spectrum.tiff";
import Link from "../components/links/Link.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home">
	<main>
		<div class="container">
			<div class="container-hero">
				<section class="hero-text">
					<h1>Welcome to Gare</h1>
					<p>New Zealand Computer Specialists</p>
				</section>
				<div class="grid-hero">
					<HeroImage src={Keys} alt="Keys" rotation={3} />
					<HeroImage src={Spectrum} alt="Spectrum" rotation={-3} />
					<HeroImage src={Chips} alt="Chips" rotation={3} />
					<HeroImage src={Schematic} alt="Schematic" rotation={-3} />
				</div>
				<section class="hero-bottom">
					<p>Got a computer problem?</p>
					<p><Link href="/contact" aria-label="contact">Get in touch.</Link></p>
					<p>We'll fix your machine or build you a new one.</p>
				</section>
			</div>
		</div>
	</main>
</Layout>

<style>
	main {
		max-width: min(75ch, 100vw);
		font-size: clamp(0.9rem, 2vw, 1.2rem);
		padding: 1rem;
	}

	.hero-text {
		text-align: center;
		padding: 1rem 0;
	}

	.hero-bottom {
		text-align: center;
		padding: 1rem 0;
	}
</style>
